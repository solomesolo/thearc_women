{
  "name": "the-arc-woman",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 3000 -H 127.0.0.1",
    "dev:bootstrap": "prisma migrate deploy && prisma db seed && npm run backfill:sections-8-9",
    "dev:full": "npm run dev:bootstrap && npm run dev",
    "dev:only": "next dev --webpack -p 3000 -H 127.0.0.1",
    "dev:watchdog": "DEV_WATCHDOG_START_CMD=\"npm run dev:only\" node scripts/dev_watchdog.mjs",
    "dev:ui": "NEXT_TELEMETRY_DISABLED=1 NEXT_DISABLE_BUILD_WORKER=1 CI=1 next dev --webpack -p 3000 -H 127.0.0.1",
    "dev:check": "lsof -nP -iTCP:3000 -sTCP:LISTEN || true",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "scrape:pubmed": "tsx scripts/scrape_pubmed.ts",
    "scrape:pubmed:raw": "tsx scripts/scrape_pubmed_raw.ts",
    "process:articles": "tsx scripts/process_articles.ts",
    "backfill:sections-8-9": "tsx scripts/backfill_sections_8_9.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:setup": "prisma migrate deploy && prisma db seed && npm run backfill:sections-8-9",
    "db:push": "prisma db push",
    "test": "vitest run tests/engine",
    "test:watch": "vitest tests/engine"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@supabase/supabase-js": "^2.49.1",
    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.34.3",
    "jose": "^4.15.9",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "pg": "^8.19.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/node": "^4.2.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}
