generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Raw scraped medical articles from external sources (PubMed, guidelines, etc.)
model RawMedicalArticle {
  id               String   @id @default(uuid()) @db.Uuid
  source           String
  sourceUrl        String
  title            String
  authors          String?
  journal          String?
  publicationDate  DateTime?
  abstract         String?
  fullText         String?
  keywords         String[] @default([]) // PostgreSQL text[]
  doi              String?
  scrapedAt        DateTime @default(now())
  processed        Boolean  @default(false)

  knowledgeArticles KnowledgeArticle[]

  @@map("raw_medical_articles")
}

/// Structured knowledge article derived from a raw medical article.
/// approvalStatus: "pending" = needs admin approval; "approved" = shown on blog.
model KnowledgeArticle {
  id                 String   @id @default(uuid()) @db.Uuid
  rawArticleId       String?  @db.Uuid
  rawArticle         RawMedicalArticle? @relation(fields: [rawArticleId], references: [id])

  title              String
  summary            String?
  keyFindings        String[] @default([])
  biologicalSystems  String[] @default([])
  symptoms           String[] @default([])
  biomarkers         String[] @default([])
  rootCauses         String[] @default([])
  preventiveTopics   String[] @default([])
  interventionTypes  String[] @default([])
  lifeStages         String[] @default([])
  evidenceLevel      String?
  approvalStatus     String?  @default("pending") // "pending" | "approved" — only approved shown on blog
  createdAt          DateTime @default(now())

  contents           KnowledgeContent[]
  labels             ArticleLabel[]

  @@map("knowledge_articles")
}

/// Rich narrative knowledge content attached to a knowledge article
model KnowledgeContent {
  id                   String   @id @default(uuid()) @db.Uuid
  articleId            String   @db.Uuid
  article              KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  scienceExplained     String?
  patternsAndRootCauses String?
  preventiveInsights   String?
  clinicalContext      String?
  qualityScore         Float?
  createdAt            DateTime @default(now())

  @@map("knowledge_content")
}

/// Flat label entries for flexible tagging and analytics
model ArticleLabel {
  id         String   @id @default(uuid()) @db.Uuid
  articleId  String   @db.Uuid
  article    KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  labelType  String
  labelValue String
  createdAt  DateTime @default(now())

  @@map("article_labels")
}

/// Pipeline event log (scrape errors, LLM failures, JSON errors, duplicates, label failures)
model PipelineLog {
  id        String   @id @default(uuid()) @db.Uuid
  event     String   // e.g. scrape_error, llm_failure, json_parse_error, duplicate_article, label_mapping_failure
  message   String?
  payload   Json?    // optional context (article_id, error detail, etc.)
  createdAt DateTime @default(now())

  @@map("pipeline_logs")
}

/// Top-level article metadata (editorial or pipeline-generated)
model Article {
  id             Int              @id @default(autoincrement())
  slug           String           @unique
  title          String
  excerpt        String
  pillar         String?
  category       String?
  evidenceLevel  String?
  studyTypes     String?          // e.g. observational, randomized (comma or JSON)
  consensusStatus String?
  coverImageUrl  String?
  lensMapping    String[]        @default([])  // tag slugs or IDs for "lens"
  isPublished    Boolean          @default(false)
  isArchived     Boolean          @default(false)
  publishedAt    DateTime?
  readingTimeMinutes Int?         // computed on save/publish from sections + excerpt
  /// When set, article was generated by the pipeline (scraper + LLM); admin approves by publishing
  rawArticleId   String?          @db.Uuid

  sections        ArticleSection[]
  sources         ArticleSource[]
  tagJoins        ArticleTagJoin[]
  savedBy         SavedArticle[]
  views           ArticleView[]
  collectionJoins CollectionArticle[]
  planItems       PlanItem[]

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

/// Individual structured sections (1–9) for an article. 8 = Action protocol, 9 = Tracking framework.
model ArticleSection {
  id        Int      @id @default(autoincrement())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId Int

  /// 1–9 position in the article (6–9 gated: 6–7 legacy, 8 Action protocol, 9 Tracking framework)
  sectionIndex Int
  /// Optional label for the section in the UI
  title        String?
  /// Markdown / rich text content
  body         String

  /// Sections 6–9 gated by default in product experience
  isGated      Boolean @default(false)
  /// Preview text for gated sections (required when isGated)
  preview      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([articleId, sectionIndex])
}

/// Source / citation for an article (e.g., paper, guideline)
model ArticleSource {
  id        Int      @id @default(autoincrement())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId Int

  label        String  // short label e.g. Lancet 2024 study
  url          String?
  evidenceNote String? // optional context on strength / limitations

  createdAt DateTime @default(now())
}

/// Taxonomy types used for filtering
enum TaxonomyType {
  lifeStage
  symptom
  bodySystem
  preventiveFocus
  trending
  biomarker
  hormone
  goal
  rootCause
  interventionType
  evidenceLevel
  contentAccess
}

/// A single taxonomy tag (e.g., \"Perimenopause\", \"Cortisol\", \"Sleep disruption\")
model TaxonomyTag {
  id    Int          @id @default(autoincrement())
  slug  String       @unique
  label String
  type  TaxonomyType

  articleJoins ArticleTagJoin[]
}

/// Join table between Article and TaxonomyTag
model ArticleTagJoin {
  article   Article     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId Int

  tag       TaxonomyTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     Int

  @@id([articleId, tagId])
  @@index([tagId])
}

/// MVP: subscription status by email (no full User table required for credentials auth)
model Subscriber {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
}

/// Health survey + personalization profile (linked by email from session)
model UserProfile {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  lifeStage      String?
  cyclePattern   String?
  goals          String[] @default([])  // PostgreSQL text[]
  symptoms       String[] @default([])
  riskFactors    String[] @default([])
  trainingVolume String?
  stressLevel    String?
  generatedTags   String[] @default([])  // rule-based from above
  surveyResponses Json?                  // full Arc intake variable_id -> value
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── User Features ────────────────────────────────────────────────────────────

/// Article saved by a user (email-keyed, no User table)
model SavedArticle {
  id        Int      @id @default(autoincrement())
  email     String
  articleId Int      @map("article_id")
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  savedAt   DateTime @default(now()) @map("saved_at")

  @@unique([email, articleId])
  @@index([email])
  @@map("saved_articles")
}

/// Article view event for recently-viewed tracking (append-only)
model ArticleView {
  id        Int      @id @default(autoincrement())
  email     String
  articleId Int      @map("article_id")
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now()) @map("viewed_at")

  @@index([email])
  @@map("article_views")
}

/// User-created collection of articles
model Collection {
  id        Int                 @id @default(autoincrement())
  email     String
  name      String
  colorKey  String              @default("stone") @map("color_key")
  createdAt DateTime            @default(now()) @map("created_at")
  articles  CollectionArticle[]

  @@index([email])
  @@map("collections")
}

/// Join table: articles inside a collection
model CollectionArticle {
  collectionId Int @map("collection_id")
  articleId    Int @map("article_id")
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  article      Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@id([collectionId, articleId])
  @@map("collection_articles")
}

/// User health plan
model HealthPlan {
  id         Int        @id @default(autoincrement())
  email      String
  name       String
  status     String     @default("active")   // active | paused | completed
  sourceType String?    @map("source_type") // protocol | articles | manual
  createdAt  DateTime   @default(now()) @map("created_at")
  items      PlanItem[]
  logs       ActionLog[]

  @@index([email])
  @@map("health_plans")
}

/// Individual item inside a health plan
model PlanItem {
  id          Int        @id @default(autoincrement())
  planId      Int        @map("plan_id")
  plan        HealthPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  title       String
  description String?
  timing      String     @default("anytime") // morning | evening | weekly | anytime
  sortOrder   Int        @default(0) @map("sort_order")
  isDone      Boolean    @default(false) @map("is_done")
  articleId   Int?       @map("article_id")
  article     Article?   @relation(fields: [articleId], references: [id], onDelete: SetNull)
  logs        ActionLog[]

  @@map("plan_items")
}

/// Action execution log entry
model ActionLog {
  id       Int         @id @default(autoincrement())
  email    String
  planId   Int?        @map("plan_id")
  plan     HealthPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  itemId   Int?        @map("item_id")
  item     PlanItem?   @relation(fields: [itemId], references: [id], onDelete: SetNull)
  note     String?
  loggedAt DateTime    @default(now()) @map("logged_at")

  @@index([email])
  @@map("action_logs")
}

/// In-app notification for a user
model UserNotification {
  id        Int      @id @default(autoincrement())
  email     String
  type      String   @default("system_reminder") // action_critical | knowledge_update | system_reminder
  title     String
  body      String
  isRead    Boolean  @default(false) @map("is_read")
  actionUrl String?  @map("action_url")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("user_notifications")
}

