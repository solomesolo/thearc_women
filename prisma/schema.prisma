generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Raw scraped medical articles from external sources (PubMed, guidelines, etc.)
model RawMedicalArticle {
  id               String   @id @default(uuid()) @db.Uuid
  source           String
  sourceUrl        String
  title            String
  authors          String?
  journal          String?
  publicationDate  DateTime?
  abstract         String?
  fullText         String?
  keywords         String[] @default([]) // PostgreSQL text[]
  doi              String?
  scrapedAt        DateTime @default(now())
  processed        Boolean  @default(false)

  knowledgeArticles KnowledgeArticle[]

  @@map("raw_medical_articles")
}

/// Structured knowledge article derived from a raw medical article.
/// approvalStatus: "pending" = needs admin approval; "approved" = shown on blog.
model KnowledgeArticle {
  id                 String   @id @default(uuid()) @db.Uuid
  rawArticleId       String?  @db.Uuid
  rawArticle         RawMedicalArticle? @relation(fields: [rawArticleId], references: [id])

  title              String
  summary            String?
  keyFindings        String[] @default([])
  biologicalSystems  String[] @default([])
  symptoms           String[] @default([])
  biomarkers         String[] @default([])
  rootCauses         String[] @default([])
  preventiveTopics   String[] @default([])
  interventionTypes  String[] @default([])
  lifeStages         String[] @default([])
  evidenceLevel      String?
  approvalStatus     String?  @default("pending") // "pending" | "approved" — only approved shown on blog
  createdAt          DateTime @default(now())

  contents           KnowledgeContent[]
  labels             ArticleLabel[]

  @@map("knowledge_articles")
}

/// Rich narrative knowledge content attached to a knowledge article
model KnowledgeContent {
  id                   String   @id @default(uuid()) @db.Uuid
  articleId            String   @db.Uuid
  article              KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  scienceExplained     String?
  patternsAndRootCauses String?
  preventiveInsights   String?
  clinicalContext      String?
  qualityScore         Float?
  createdAt            DateTime @default(now())

  @@map("knowledge_content")
}

/// Flat label entries for flexible tagging and analytics
model ArticleLabel {
  id         String   @id @default(uuid()) @db.Uuid
  articleId  String   @db.Uuid
  article    KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  labelType  String
  labelValue String
  createdAt  DateTime @default(now())

  @@map("article_labels")
}

/// Pipeline event log (scrape errors, LLM failures, JSON errors, duplicates, label failures)
model PipelineLog {
  id        String   @id @default(uuid()) @db.Uuid
  event     String   // e.g. scrape_error, llm_failure, json_parse_error, duplicate_article, label_mapping_failure
  message   String?
  payload   Json?    // optional context (article_id, error detail, etc.)
  createdAt DateTime @default(now())

  @@map("pipeline_logs")
}

/// Top-level article metadata (editorial or pipeline-generated)
model Article {
  id             Int              @id @default(autoincrement())
  slug           String           @unique
  title          String
  excerpt        String
  pillar         String?
  category       String?
  evidenceLevel  String?
  studyTypes     String?          // e.g. observational, randomized (comma or JSON)
  consensusStatus String?
  coverImageUrl  String?
  lensMapping    String[]        @default([])  // tag slugs or IDs for "lens"
  isPublished    Boolean          @default(false)
  isArchived     Boolean          @default(false)
  publishedAt    DateTime?
  readingTimeMinutes Int?         // computed on save/publish from sections + excerpt
  /// When set, article was generated by the pipeline (scraper + LLM); admin approves by publishing
  rawArticleId   String?          @db.Uuid

  sections     ArticleSection[]
  sources      ArticleSource[]
  tagJoins     ArticleTagJoin[]

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

/// Individual structured sections (1–9) for an article. 8 = Action protocol, 9 = Tracking framework.
model ArticleSection {
  id        Int      @id @default(autoincrement())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId Int

  /// 1–9 position in the article (6–9 gated: 6–7 legacy, 8 Action protocol, 9 Tracking framework)
  sectionIndex Int
  /// Optional label for the section in the UI
  title        String?
  /// Markdown / rich text content
  body         String

  /// Sections 6–9 gated by default in product experience
  isGated      Boolean @default(false)
  /// Preview text for gated sections (required when isGated)
  preview      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([articleId, sectionIndex])
}

/// Source / citation for an article (e.g., paper, guideline)
model ArticleSource {
  id        Int      @id @default(autoincrement())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId Int

  label        String  // short label e.g. Lancet 2024 study
  url          String?
  evidenceNote String? // optional context on strength / limitations

  createdAt DateTime @default(now())
}

/// Taxonomy types used for filtering
enum TaxonomyType {
  lifeStage
  symptom
  bodySystem
  preventiveFocus
  trending
  biomarker
  hormone
  goal
  rootCause
  interventionType
  evidenceLevel
  contentAccess
}

/// A single taxonomy tag (e.g., \"Perimenopause\", \"Cortisol\", \"Sleep disruption\")
model TaxonomyTag {
  id    Int          @id @default(autoincrement())
  slug  String       @unique
  label String
  type  TaxonomyType

  articleJoins ArticleTagJoin[]
}

/// Join table between Article and TaxonomyTag
model ArticleTagJoin {
  article   Article     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId Int

  tag       TaxonomyTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     Int

  @@id([articleId, tagId])
  @@index([tagId])
}

/// MVP: subscription status by email (no full User table required for credentials auth)
model Subscriber {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
}

/// Health survey + personalization profile (linked by email from session)
model UserProfile {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  lifeStage      String?
  cyclePattern   String?
  goals          String[] @default([])  // PostgreSQL text[]
  symptoms       String[] @default([])
  riskFactors    String[] @default([])
  trainingVolume String?
  stressLevel    String?
  generatedTags   String[] @default([])  // rule-based from above
  surveyResponses Json?                  // full Arc intake variable_id -> value
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

